      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "🗄️ DATABASE\nMySQL + Drizzle ORM\n─────────────────────────────\n📋 inspectors\n  id, inspectorId (auto-gen)\n  name, email, password\n  phone, designation, region\n  role (inspector | admin)\n  createdAt\n\n📋 inspections\n  id, inspectorId (FK)\n  cropType, productionType\n  totalStages, status\n  createdAt, updatedAt\n\n📋 field_registrations\n  id, inspectionId (FK)\n  farmerName, farmerContact\n  fieldLocation\n  latitude, longitude\n  fieldBoundary (JSON)\n  documentUrl\n\n📋 stage_data\n  id, inspectionId (FK)\n  stageNumber, stageName\n  uniformityPercentage\n  offTypePercentage\n  diseases (JSON)\n  additionalChecks (JSON)\n  notes, status, completedAt\n\n📋 stage_photos\n  id, stageDataId (FK)\n  photoUrl, uploadedAt\n\n📋 reports\n  id, inspectionId (FK)\n  verdict, summaryNotes\n  pdfUrl, submittedAt\n\n☁️ Hosted on: Railway MySQL",
      "fontSize": 11,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "🗄️ DATABASE\nMySQL + Drizzle ORM\n─────────────────────────────\n📋 inspectors\n  id, inspectorId (auto-gen)\n  name, email, password\n  phone, designation, region\n  role (inspector | admin)\n  createdAt\n\n📋 inspections\n  id, inspectorId (FK)\n  cropType, productionType\n  totalStages, status\n  createdAt, updatedAt\n\n📋 field_registrations\n  id, inspectionId (FK)\n  farmerName, farmerContact\n  fieldLocation\n  latitude, longitude\n  fieldBoundary (JSON)\n  documentUrl\n\n📋 stage_data\n  id, inspectionId (FK)\n  stageNumber, stageName\n  uniformityPercentage\n  offTypePercentage\n  diseases (JSON)\n  additionalChecks (JSON)\n  notes, status, completedAt\n\n📋 stage_photos\n  id, stageDataId (FK)\n  photoUrl, uploadedAt\n\n📋 reports\n  id, inspectionId (FK)\n  verdict, summaryNotes\n  pdfUrl, submittedAt\n\n☁️ Hosted on: Railway MySQL",
